FROM node:18-bullseye AS build

WORKDIR /app

ARG REACT_APP_NODE_ENV=production
ARG REACT_APP_MOCK_AUTH=false
ARG REACT_APP_BASE_URL=http://localhost:3000
ARG REACT_APP_SOCKET_URL=http://localhost:8081
ARG REACT_APP_MEDIA_URL=http://localhost:3000
ARG REACT_APP_FRONT_BASE_URL=http://localhost
ARG REACT_APP_GOOGLE_MAP_API_KEY=
ARG REACT_APP_FIREBASE_API_KEY=
ARG REACT_APP_FIREBASE_AUTHDOMAIN=
ARG REACT_APP_FIREBASE_DBURL=
ARG REACT_APP_FIREBASE_PROID=
ARG REACT_APP_FIREBASE_STORAGE_BUCKET=
ARG REACT_APP_FIREBASE_MSG_SENDID=
ARG REACT_APP_FIREBASE_APP_ID=
ARG REACT_APP_FIREBASE_MEASURE_ID=
ARG REACT_APP_GOOGLE_ONE_TAP_SIGNIN_CLIENT_ID=

ENV REACT_APP_NODE_ENV=$REACT_APP_NODE_ENV \
    REACT_APP_MOCK_AUTH=$REACT_APP_MOCK_AUTH \
    REACT_APP_BASE_URL=$REACT_APP_BASE_URL \
    REACT_APP_SOCKET_URL=$REACT_APP_SOCKET_URL \
    REACT_APP_MEDIA_URL=$REACT_APP_MEDIA_URL \
    REACT_APP_FRONT_BASE_URL=$REACT_APP_FRONT_BASE_URL \
    REACT_APP_GOOGLE_MAP_API_KEY=$REACT_APP_GOOGLE_MAP_API_KEY \
    REACT_APP_FIREBASE_API_KEY=$REACT_APP_FIREBASE_API_KEY \
    REACT_APP_FIREBASE_AUTHDOMAIN=$REACT_APP_FIREBASE_AUTHDOMAIN \
    REACT_APP_FIREBASE_DBURL=$REACT_APP_FIREBASE_DBURL \
    REACT_APP_FIREBASE_PROID=$REACT_APP_FIREBASE_PROID \
    REACT_APP_FIREBASE_STORAGE_BUCKET=$REACT_APP_FIREBASE_STORAGE_BUCKET \
    REACT_APP_FIREBASE_MSG_SENDID=$REACT_APP_FIREBASE_MSG_SENDID \
    REACT_APP_FIREBASE_APP_ID=$REACT_APP_FIREBASE_APP_ID \
    REACT_APP_FIREBASE_MEASURE_ID=$REACT_APP_FIREBASE_MEASURE_ID \
    REACT_APP_GOOGLE_ONE_TAP_SIGNIN_CLIENT_ID=$REACT_APP_GOOGLE_ONE_TAP_SIGNIN_CLIENT_ID

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:alpine

COPY --from=build /app/build /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
